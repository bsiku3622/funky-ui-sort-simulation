# ── Python (backend) ──
backend/.venv/
**/__pycache__/
*.py[cod]
backend/build/
backend/dist/
build/
dist/
# PyInstaller 자동 생성 spec 은 무시하되, deploy 의 손수 작성한 spec 은 추적
*.spec
!deploy/*.spec

# ── Node / Vite (frontend) ──
frontend/node_modules/
frontend/dist/
frontend/*.tsbuildinfo
frontend/.vite/
frontend/vite.config.*.timestamp-*
# 빌드 시 backend/sorts 에서 복사되는 웹 엔진용 .py (생성물)
frontend/public/py/

# ── 로그 ──
*.log
npm-debug.log*

# ── OS / 에디터 ──
.DS_Store
Thumbs.db
.idea/
.vscode/
*.swp
